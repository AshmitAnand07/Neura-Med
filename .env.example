# NeuraMed AI Backend - Environment Template
# Copy this to .env (Local) or add to Render Dashboard (Cloud)

# 1. FIREBASE CONFIGURATION
# Set the entire serviceAccountKey.json content here as a single-line JSON string
# or ensure the file exists as 'serviceAccountKey.json' in the root.
FIREBASE_SERVICE_ACCOUNT_JSON='{"type": "service_account", "project_id": "...", "private_key": "...", ...}'

# 2. MODEL PATHS (Defaults are fine for root)
INTERACTION_MODEL_PATH=interaction_model.pkl
ADHERENCE_MODEL_PATH=adherence_model.pkl
ENCODER_PATH=drug_encoder.pkl

# 3. PRODUCTION SETTINGS
PORT=10000
LOG_LEVEL=INFO
