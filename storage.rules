rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /medicines/{userId}/{imageId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /prescriptions/{userId}/{imageId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
